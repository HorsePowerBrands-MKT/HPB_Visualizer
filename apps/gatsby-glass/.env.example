# Google Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration (server-side)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Supabase Configuration (client-side — exposed to the browser for Auth)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Optional: Resend API for email notifications
RESEND_API_KEY=your_resend_api_key_here

# Constant Contact CRM (SharpSpring) — used to push leads to the CRM
SHARPSPRING_ACCOUNT_ID=your_sharpspring_account_id_here
SHARPSPRING_SECRET_KEY=your_sharpspring_secret_key_here
